.env.template
OPENAI_API_KEY=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
DATABASE_URL=postgresql://postgres:postgres@localhost/care_companion
REDIS_URL=redis://localhost:6379

# Server Configuration
DEBUG=True
LOG_LEVEL=INFO
ENVIRONMENT=development

# API Configuration
API_V1_STR=/api/v1
SECRET_KEY=your-secret-key-here

# Model Configuration
OPENAI_MODEL=gpt-4o-mini
MODEL_PATH=app/models/disease_model.pkl

# Feature Flags
ENABLE_STREAMING=True
ENABLE_SAFETY_CHECKS=True
ENABLE_DIAGNOSIS=True
ENABLE_RECOMMENDATIONS=True

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# CORS Settings
CORS_ORIGINS=http://localhost:3000,http://localhost:8000,http://localhost:5173

# Email Configuration (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=Care Companion <noreply@carecompanion.com>

# Monitoring
SENTRY_DSN=
ENABLE_METRICS=False

# File Upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760